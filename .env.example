VITE_API_BASE_URL=

# Alternatif isim (VITE_API_BASE_URL boşsa kullanılır):
# VITE_API_URL=

# Yerel geliştirme proxy hedefi (backend PORT ile aynı olmalı; varsayılan 4000)
# VITE_DEV_API_PROXY=http://localhost:4000

# Yerel geliştirme: VITE_API_BASE_URL boş → Vite proxy ile /api istekleri VITE_DEV_API_PROXY adresine gider.
# Doğrudan backend URL: http://localhost:4000
#
# Production (muvekkil.woontegra.com): VITE_API_BASE_URL boş bırakın — istekler aynı origin /api üzerinden
# Vercel proxy ile Railway backend'e gider (vercel.json). Railway *.railway.app DNS sorunlarından kaçınır.
# VITE_API_BASE_URL=

# Admin “Yeni büro” başarı ekranında kopyalanacak giriş adresi (ör. canlı domain).
# Boşsa tarayıcıdaki origin + /login kullanılır.
# VITE_PUBLIC_APP_LOGIN_URL=https://muvekkil.woontegra.com/login
