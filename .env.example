VITE_API_BASE_URL=

# Alternatif isim (VITE_API_BASE_URL boşsa kullanılır):
# VITE_API_URL=

# Yerel geliştirme: boş bırakın → Vite proxy ile /api istekleri http://localhost:4000 adresine gider.
# Doğrudan backend URL: http://localhost:4000
# Production build: Railway backend URL, örn:
# VITE_API_BASE_URL=https://muvekkil-kasasi-backend-production.up.railway.app

